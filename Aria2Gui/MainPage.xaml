<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Aria2Gui.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:vm="using:Aria2Gui.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="RowIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <CommandBar
            Grid.Row="0"
            Background="Transparent"
            DefaultLabelPosition="Right"
            IsOpen="False"
            HorizontalAlignment="Left">
            <AppBarButton
                Label="Добавить"
                Command="{x:Bind ViewModel.AddDownloadCommand}"
                AutomationProperties.Name="Добавить загрузку"
                AutomationProperties.AutomationId="AddDownloadButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="N" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Label="Возобновить все"
                Command="{x:Bind ViewModel.ResumeAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                AutomationProperties.Name="Возобновить все загрузки"
                AutomationProperties.AutomationId="ResumeAllButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE768;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Label="Пауза всем"
                Command="{x:Bind ViewModel.PauseAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                AutomationProperties.Name="Приостановить все загрузки"
                AutomationProperties.AutomationId="PauseAllButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE769;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Label="Очистить"
                Command="{x:Bind ViewModel.ClearStoppedCommand}"
                IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                AutomationProperties.Name="Очистить завершённые загрузки"
                AutomationProperties.AutomationId="ClearStoppedButton"
                ToolTipService.ToolTip="Убрать завершённые и удалённые из списка">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE894;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Label="Настройки"
                Command="{x:Bind ViewModel.OpenSettingsCommand}"
                AutomationProperties.Name="Настройки"
                AutomationProperties.AutomationId="SettingsButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Download list -->
        <ListView
            x:Name="DownloadsList"
            AutomationProperties.AutomationId="DownloadsList"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="False"
            Padding="12,0,12,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DownloadItemViewModel">
                    <Grid Padding="0,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                            FontSize="18"
                            VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind Name, Mode=OneWay}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                TextTrimming="CharacterEllipsis" />
                            <ProgressBar
                                Value="{x:Bind Progress, Mode=OneWay}"
                                Maximum="100"
                                IsIndeterminate="{x:Bind IsProgressIndeterminate, Mode=OneWay}" />
                            <TextBlock
                                Text="{x:Bind DetailsText, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                            <Button
                                Style="{StaticResource RowIconButtonStyle}"
                                Command="{x:Bind PauseResumeCommand}"
                                Visibility="{x:Bind CanPauseResume, Mode=OneWay}"
                                ToolTipService.ToolTip="{x:Bind PauseResumeTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind PauseResumeTooltip, Mode=OneWay}"
                                AutomationProperties.AutomationId="RowPauseResumeButton">
                                <FontIcon Glyph="{x:Bind PauseResumeGlyph, Mode=OneWay}" FontSize="14" />
                            </Button>
                            <Button
                                Style="{StaticResource RowIconButtonStyle}"
                                Command="{x:Bind OpenFolderCommand}"
                                ToolTipService.ToolTip="Открыть папку"
                                AutomationProperties.Name="Открыть папку"
                                AutomationProperties.AutomationId="RowOpenFolderButton">
                                <FontIcon Glyph="&#xE838;" FontSize="14" />
                            </Button>
                            <Button
                                Style="{StaticResource RowIconButtonStyle}"
                                Command="{x:Bind RemoveCommand}"
                                ToolTipService.ToolTip="Удалить из списка"
                                AutomationProperties.Name="Удалить из списка"
                                AutomationProperties.AutomationId="RowRemoveButton">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <FontIcon
                Glyph="&#xE896;"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock
                Text="Нет загрузок"
                Style="{StaticResource SubtitleTextBlockStyle}"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Text="Нажмите «Добавить» (Ctrl+N) или перетащите сюда торрент-файл"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <!-- Engine failure surface -->
        <InfoBar
            Grid.Row="1"
            VerticalAlignment="Bottom"
            Margin="12"
            Severity="Error"
            Title="aria2 не запустился"
            Message="{x:Bind ViewModel.EngineErrorText, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.HasEngineError, Mode=OneWay}" />

        <!-- Status bar -->
        <Grid
            Grid.Row="2"
            Padding="16,8"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xEC05;"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    AutomationProperties.AutomationId="EngineStatusText"
                    Text="{x:Bind ViewModel.EngineStatusText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
                <TextBlock
                    AutomationProperties.AutomationId="CountsText"
                    Text="{x:Bind ViewModel.CountsText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                AutomationProperties.AutomationId="GlobalSpeedText"
                Grid.Column="1"
                Text="{x:Bind ViewModel.GlobalSpeedText, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
