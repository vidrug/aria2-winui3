<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Aria2Gui.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:vm="using:Aria2Gui.ViewModels"
    xmlns:views="using:Aria2Gui.Views"
    xmlns:helpers="using:Aria2Gui.Helpers"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ColumnHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <!-- The grab strip straddles the column divider: negative top/bottom fill the
             header's 8px vertical padding and the negative right (-(4 + Width/2)) centres
             the 12px handle over the 8px column gap. This deliberate overlap is the one
             place negative margins are used. -->
        <Style x:Key="ColumnResizeHandleStyle" TargetType="helpers:ResizeHandle">
            <Setter Property="Width" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,-8,-10,-8" />
        </Style>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,8,4" />
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Margin" Value="0,0,16,4" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar (hidden while the settings page is shown) -->
        <CommandBar
            Grid.Row="0"
            Background="Transparent"
            DefaultLabelPosition="Right"
            IsOpen="False"
            HorizontalAlignment="Left"
            Visibility="{x:Bind local:MainPage.CollapsedIf(ViewModel.SettingsOpen), Mode=OneWay}">
            <AppBarButton
                Label="Добавить"
                Command="{x:Bind ViewModel.AddDownloadCommand}"
                AutomationProperties.Name="Добавить загрузку"
                AutomationProperties.AutomationId="AddDownloadButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="N" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Label="Возобновить"
                Command="{x:Bind ViewModel.ResumeSelectedCommand}"
                IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                AutomationProperties.Name="Возобновить выбранные"
                AutomationProperties.AutomationId="ResumeSelectedButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE768;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Label="Пауза"
                Command="{x:Bind ViewModel.PauseSelectedCommand}"
                IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                AutomationProperties.Name="Приостановить выбранные"
                AutomationProperties.AutomationId="PauseSelectedButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE769;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Label="Удалить"
                Command="{x:Bind ViewModel.RemoveSelectedCommand}"
                IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                AutomationProperties.Name="Удалить выбранные из списка"
                AutomationProperties.AutomationId="RemoveSelectedButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74D;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Delete" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Label="Настройки"
                Command="{x:Bind ViewModel.OpenSettingsCommand}"
                AutomationProperties.Name="Настройки"
                AutomationProperties.AutomationId="SettingsButton"
                PointerEntered="AnimatedButton_PointerEntered"
                PointerExited="AnimatedButton_PointerExited">
                <AppBarButton.Icon>
                    <AnimatedIcon x:Name="SettingsAnimatedIcon">
                        <AnimatedIcon.Source>
                            <animatedvisuals:AnimatedSettingsVisualSource />
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <FontIconSource Glyph="&#xE713;" />
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Label="Ещё"
                AutomationProperties.Name="Ещё действия"
                AutomationProperties.AutomationId="MoreButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE712;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Text="Возобновить все"
                            Command="{x:Bind ViewModel.ResumeAllCommand}"
                            IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                            AutomationProperties.AutomationId="ResumeAllButton">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE768;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem
                            Text="Пауза всем"
                            Command="{x:Bind ViewModel.PauseAllCommand}"
                            IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                            AutomationProperties.AutomationId="PauseAllButton">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE769;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Text="Очистить завершённые"
                            Command="{x:Bind ViewModel.ClearStoppedCommand}"
                            IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                            AutomationProperties.AutomationId="ClearStoppedButton">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE894;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
        </CommandBar>

        <!-- Sidebar | main area (hidden while the settings page is shown) -->
        <Grid Grid.Row="1" Visibility="{x:Bind local:MainPage.CollapsedIf(ViewModel.SettingsOpen), Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- Status filters -->
            <ListView
                x:Name="FiltersList"
                AutomationProperties.AutomationId="FiltersList"
                Grid.Column="0"
                Padding="4,8,4,8"
                SelectionMode="Single"
                ItemsSource="{x:Bind ViewModel.Filters, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="36" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FilterItemViewModel">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Glyph="{x:Bind Glyph}"
                                FontSize="14"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Title}"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind Count, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <toolkit:GridSplitter
                Grid.Column="1"
                AutomationProperties.AutomationId="SidebarSplitter"
                AutomationProperties.Name="Ширина боковой панели"
                Width="8"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!-- Table + details -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="232" MinHeight="128" MaxHeight="500" />
                </Grid.RowDefinitions>

                <!-- Table: header and rows share one horizontal scroller so they stay
                     aligned and scroll together when the columns overflow the width. -->
                <ScrollViewer
                    Grid.Row="0"
                    x:Name="TableScroll"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled"
                    SizeChanged="TableScroll_SizeChanged">
                    <Grid x:Name="TableContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                <!-- Column headers: dividers resize columns; right-click toggles which show. -->
                <Grid
                    Grid.Row="0"
                    Padding="16,8,12,8"
                    ColumnSpacing="8"
                    Background="Transparent"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid.ContextFlyout>
                        <MenuFlyout>
                            <ToggleMenuFlyoutItem Text="Размер" Tag="size" AutomationProperties.AutomationId="ColumnToggleSize" IsChecked="{x:Bind ViewModel.Columns.SizeVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Прогресс" Tag="progress" AutomationProperties.AutomationId="ColumnToggleProgress" IsChecked="{x:Bind ViewModel.Columns.ProgressVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Статус" Tag="status" AutomationProperties.AutomationId="ColumnToggleStatus" IsChecked="{x:Bind ViewModel.Columns.StatusVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Сиды" Tag="seeds" AutomationProperties.AutomationId="ColumnToggleSeeds" IsChecked="{x:Bind ViewModel.Columns.SeedsVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Пиры" Tag="peers" AutomationProperties.AutomationId="ColumnTogglePeers" IsChecked="{x:Bind ViewModel.Columns.PeersVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Загрузка" Tag="down" AutomationProperties.AutomationId="ColumnToggleDown" IsChecked="{x:Bind ViewModel.Columns.DownVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Отдача" Tag="up" AutomationProperties.AutomationId="ColumnToggleUp" IsChecked="{x:Bind ViewModel.Columns.UpVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Осталось" Tag="eta" AutomationProperties.AutomationId="ColumnToggleEta" IsChecked="{x:Bind ViewModel.Columns.EtaVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem Text="Рейтинг" Tag="ratio" AutomationProperties.AutomationId="ColumnToggleRatio" IsChecked="{x:Bind ViewModel.Columns.RatioVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                        </MenuFlyout>
                    </Grid.ContextFlyout>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.NameWidth, Mode=OneWay}" MinWidth="120" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.SizeWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.ProgressWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.StatusWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.SeedsWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.PeersWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.DownWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.UpWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.EtaWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.RatioWidth, Mode=OneWay}" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Имя" Style="{StaticResource ColumnHeaderTextStyle}" />
                    <helpers:ResizeHandle Grid.Column="0" Tag="name" AutomationProperties.AutomationId="ResizeHandleName" AutomationProperties.Name="Изменить ширину столбца «Имя»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" />
                    <TextBlock Grid.Column="1" Text="Размер" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SizeVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="1" Tag="size" AutomationProperties.AutomationId="ResizeHandleSize" AutomationProperties.Name="Изменить ширину столбца «Размер»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SizeVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="2" Text="Прогресс" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.ProgressVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="2" Tag="progress" AutomationProperties.AutomationId="ResizeHandleProgress" AutomationProperties.Name="Изменить ширину столбца «Прогресс»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.ProgressVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="3" Text="Статус" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.StatusVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="3" Tag="status" AutomationProperties.AutomationId="ResizeHandleStatus" AutomationProperties.Name="Изменить ширину столбца «Статус»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.StatusVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="4" Text="Сиды" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SeedsVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="4" Tag="seeds" AutomationProperties.AutomationId="ResizeHandleSeeds" AutomationProperties.Name="Изменить ширину столбца «Сиды»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SeedsVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="5" Text="Пиры" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.PeersVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="5" Tag="peers" AutomationProperties.AutomationId="ResizeHandlePeers" AutomationProperties.Name="Изменить ширину столбца «Пиры»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.PeersVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="6" Text="Загрузка" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.DownVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="6" Tag="down" AutomationProperties.AutomationId="ResizeHandleDown" AutomationProperties.Name="Изменить ширину столбца «Загрузка»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.DownVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="7" Text="Отдача" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UpVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="7" Tag="up" AutomationProperties.AutomationId="ResizeHandleUp" AutomationProperties.Name="Изменить ширину столбца «Отдача»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UpVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="8" Text="Осталось" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.EtaVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="8" Tag="eta" AutomationProperties.AutomationId="ResizeHandleEta" AutomationProperties.Name="Изменить ширину столбца «Осталось»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.EtaVisible), Mode=OneWay}" />
                    <TextBlock Grid.Column="9" Text="Рейтинг" Style="{StaticResource ColumnHeaderTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.RatioVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="9" Tag="ratio" AutomationProperties.AutomationId="ResizeHandleRatio" AutomationProperties.Name="Изменить ширину столбца «Рейтинг»" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.RatioVisible), Mode=OneWay}" />
                </Grid>

                <!-- Downloads table -->
                <ListView
                    x:Name="DownloadsList"
                    AutomationProperties.AutomationId="DownloadsList"
                    Grid.Row="1"
                    Padding="0"
                    SelectionMode="Extended"
                    SelectionChanged="DownloadsList_SelectionChanged"
                    ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="16,0,12,0" />
                            <Setter Property="MinHeight" Value="36" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DownloadItemViewModel">
                            <Grid ColumnSpacing="8" DoubleTapped="Row_DoubleTapped" Background="Transparent">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Text="{x:Bind PauseResumeText, Mode=OneWay}"
                                            Command="{x:Bind PauseResumeCommand}"
                                            IsEnabled="{x:Bind CanPauseResume, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE769;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Открыть папку" Command="{x:Bind OpenFolderCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE838;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Text="Копировать magnet-ссылку"
                                            Command="{x:Bind CopyMagnetCommand}"
                                            Visibility="{x:Bind HasMagnet, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE71B;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Удалить из списка" Command="{x:Bind RemoveCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Удалить с файлами…" Command="{x:Bind RemoveWithFilesCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74E;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{x:Bind Columns.NameWidth, Mode=OneWay}" MinWidth="120" />
                                    <ColumnDefinition Width="{x:Bind Columns.SizeWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.ProgressWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.StatusWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.SeedsWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.PeersWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.DownWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.UpWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.EtaWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.RatioWidth, Mode=OneWay}" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon
                                        Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                        FontSize="13"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Text="{x:Bind Name, Mode=OneWay}"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind SizeText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.SizeVisible), Mode=OneWay}" />
                                <Grid Grid.Column="2" VerticalAlignment="Center" ColumnSpacing="8" Visibility="{x:Bind local:MainPage.VisIf(Columns.ProgressVisible), Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar
                                        Value="{x:Bind Progress, Mode=OneWay}"
                                        Maximum="100"
                                        MinHeight="8"
                                        VerticalAlignment="Center"
                                        IsIndeterminate="{x:Bind IsProgressIndeterminate, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind ProgressText, Mode=OneWay}"
                                        Style="{StaticResource CellTextStyle}"
                                        TextAlignment="Right" />
                                </Grid>
                                <TextBlock Grid.Column="3" Text="{x:Bind StatusText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.StatusVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind SeedsText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.SeedsVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="5" Text="{x:Bind PeersText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.PeersVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="6" Text="{x:Bind DownSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.DownVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="7" Text="{x:Bind UpSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.UpVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="8" Text="{x:Bind EtaText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.EtaVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="9" Text="{x:Bind RatioText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.RatioVisible), Mode=OneWay}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                    </Grid>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
                    <FontIcon
                        Glyph="&#xE896;"
                        FontSize="44"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock
                        Text="Нет загрузок"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="Нажмите «Добавить» (Ctrl+N) или перетащите сюда торрент-файл"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <toolkit:GridSplitter
                    Grid.Row="1"
                    AutomationProperties.AutomationId="DetailsSplitter"
                    AutomationProperties.Name="Высота панели сведений"
                    Height="8"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Auto" />

                <!-- Details pane -->
                <Grid
                    Grid.Row="2"
                    Padding="16,4,12,8"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <SelectorBar x:Name="DetailsTabs" SelectionChanged="DetailsTabs_SelectionChanged">
                        <SelectorBarItem Text="Общие" IsSelected="True" AutomationProperties.AutomationId="DetailsTabGeneral" />
                        <SelectorBarItem Text="Файлы" AutomationProperties.AutomationId="DetailsTabFiles" />
                        <SelectorBarItem Text="Пиры" AutomationProperties.AutomationId="DetailsTabPeers" />
                    </SelectorBar>

                    <!-- No selection placeholder -->
                    <TextBlock
                        Grid.Row="1"
                        Text="Выберите загрузку, чтобы увидеть подробности"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind local:MainPage.CollapsedIf(ViewModel.HasSelection), Mode=OneWay}" />

                    <!-- General -->
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 0, ViewModel.HasSelection), Mode=OneWay}">
                        <Grid Padding="0,8,0,0" ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Сохранено в:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="5" Text="{x:Bind ViewModel.DetSavePath, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" Text="Размер:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.DetSize, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Статус:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind ViewModel.DetStatus, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="Скорость:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="{x:Bind ViewModel.DetSpeed, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="2" Text="Хеш:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Text="{x:Bind ViewModel.DetHash, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" Text="Рейтинг:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.DetRatio, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Отдано:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{x:Bind ViewModel.DetUploaded, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="Подключения:" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="5" Text="{x:Bind ViewModel.DetConnections, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                        </Grid>
                    </ScrollViewer>

                    <!-- Files -->
                    <ListView
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Padding="0"
                        SelectionMode="None"
                        ItemsSource="{x:Bind ViewModel.SelectedFiles, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 1, ViewModel.HasSelection), Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Padding" Value="0,0,12,0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileRowViewModel">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="152" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        MinWidth="0"
                                        VerticalAlignment="Center"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Качать этот файл" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind SizeText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <ProgressBar
                                        Grid.Column="3"
                                        Value="{x:Bind Progress, Mode=OneWay}"
                                        Maximum="100"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind ProgressText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Peers -->
                    <ListView
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Padding="0"
                        SelectionMode="None"
                        ItemsSource="{x:Bind ViewModel.Peers, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 2, ViewModel.HasSelection), Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Padding" Value="0,0,12,0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PeerRowViewModel">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Address, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Kind, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind DownSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind UpSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- Settings page: full width of the window, on the same Mica backdrop. -->
        <views:SettingsView
            x:Name="SettingsPage"
            Grid.Row="1"
            Closed="SettingsPage_Closed"
            Visibility="{x:Bind local:MainPage.VisIf(ViewModel.SettingsOpen), Mode=OneWay}" />

        <!-- Engine failure surface -->
        <InfoBar
            Grid.Row="1"
            VerticalAlignment="Bottom"
            Margin="12"
            Severity="Error"
            Title="aria2 не запустился"
            Message="{x:Bind ViewModel.EngineErrorText, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.HasEngineError, Mode=OneWay}" />

        <!-- Status bar -->
        <Grid
            Grid.Row="2"
            Padding="16,8"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xEC05;"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    AutomationProperties.AutomationId="EngineStatusText"
                    Text="{x:Bind ViewModel.EngineStatusText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
                <TextBlock
                    AutomationProperties.AutomationId="CountsText"
                    Text="{x:Bind ViewModel.CountsText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                AutomationProperties.AutomationId="GlobalSpeedText"
                Grid.Column="1"
                Text="{x:Bind ViewModel.GlobalSpeedText, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
