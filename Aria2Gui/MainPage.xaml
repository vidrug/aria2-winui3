<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Aria2Gui.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:Aria2Gui.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:vm="using:Aria2Gui.ViewModels"
    xmlns:views="using:Aria2Gui.Views"
    xmlns:helpers="using:Aria2Gui.Helpers"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <!-- Zebra-row tint resolved per PAGE theme: code-behind picks the dictionary by
                 this page's ActualTheme, because an Application.Current.Resources lookup
                 resolves against the OS theme fixed at launch and ignores the in-app forced
                 theme (N27). No entry for HighContrast on purpose — no stripe there. -->
            <ResourceDictionary x:Key="Light">
                <StaticResource x:Key="ZebraRowBrush" ResourceKey="SubtleFillColorTertiaryBrush" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <StaticResource x:Key="ZebraRowBrush" ResourceKey="SubtleFillColorTertiaryBrush" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast" />
        </ResourceDictionary.ThemeDictionaries>
        <!-- Sortable column headers are real Buttons (focusable, keyboard-invokable, Invoke
             pattern, Button role) but styled flat to read as plain header text. The button
             stretches to fill the whole header cell (full column width and the full header-row
             height) so hovering lights up the entire cell like a real clickable table header.
             A minimal ControlTemplate drives the rest/PointerOver/Pressed backgrounds; the 8px
             top/bottom padding lives on the button (not the Grid) so the highlight reaches the
             row's edges. The label stays left-aligned, vertically centred. -->
        <Style x:Key="ColumnHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="RootGrid"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                AutomationProperties.AccessibilityView="Raw" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <!-- The grab strip straddles the column divider: it stretches the full header-row
             height (the header Grid carries no vertical padding now — that lives inside the
             header Buttons) and the negative right (-(4 + Width/2)) centres the 12px handle
             over the 8px column gap. The handle is declared after each header Button in the
             same Grid cell, so it renders above the button and the resize drag still works.
             That single negative right is the one place a negative margin is used. -->
        <Style x:Key="ColumnResizeHandleStyle" TargetType="helpers:ResizeHandle">
            <Setter Property="Width" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,-10,0" />
        </Style>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>

        <!-- Per-download speed-limit panel, shown from a row's context menu (SpeedLimit_Click sets
             its DataContext to the clicked DownloadItemViewModel). The slider and the number box in
             each row both bind to the same VM property, so they stay linked; 0 = no limit. -->
        <Flyout x:Key="SpeedLimitFlyout">
            <StackPanel Width="324" Spacing="16">
                <TextBlock loc:Localize.Uid="SpeedLimitTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <StackPanel Spacing="4">
                    <TextBlock loc:Localize.Uid="SpeedLimitDownLabel" Style="{StaticResource DetailLabelStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" loc:Localize.Uid="SpeedLimitDownSlider" AutomationProperties.AutomationId="SpeedLimitDownSlider" Minimum="0" Maximum="100" StepFrequency="0.5" TickFrequency="10" TickPlacement="Outside" Value="{Binding SpeedLimitDownSlider, Mode=TwoWay}" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="1" loc:Localize.Uid="SpeedLimitDownBox" AutomationProperties.AutomationId="SpeedLimitDownBox" Width="92" Minimum="0" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{Binding SpeedLimitDownMb, Mode=TwoWay}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="2" loc:Localize.Uid="SpeedLimitDownUnit" AutomationProperties.AutomationId="SpeedLimitDownUnit" MinWidth="68" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SpeedLimitDownUnit, Mode=TwoWay}">
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitByte" Tag="B" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitKByte" Tag="KB" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitKBit" Tag="Kb" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitMByte" Tag="MB" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitMBit" Tag="Mb" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock loc:Localize.Uid="SpeedLimitUpLabel" Style="{StaticResource DetailLabelStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" loc:Localize.Uid="SpeedLimitUpSlider" AutomationProperties.AutomationId="SpeedLimitUpSlider" Minimum="0" Maximum="100" StepFrequency="0.5" TickFrequency="10" TickPlacement="Outside" Value="{Binding SpeedLimitUpSlider, Mode=TwoWay}" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="1" loc:Localize.Uid="SpeedLimitUpBox" AutomationProperties.AutomationId="SpeedLimitUpBox" Width="92" Minimum="0" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{Binding SpeedLimitUpMb, Mode=TwoWay}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="2" loc:Localize.Uid="SpeedLimitUpUnit" AutomationProperties.AutomationId="SpeedLimitUpUnit" MinWidth="68" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SpeedLimitUpUnit, Mode=TwoWay}">
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitByte" Tag="B" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitKByte" Tag="KB" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitKBit" Tag="Kb" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitMByte" Tag="MB" />
                            <ComboBoxItem loc:Localize.Uid="SpeedUnitMBit" Tag="Mb" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
                <TextBlock loc:Localize.Uid="SpeedLimitHint" Style="{StaticResource DetailLabelStyle}" TextWrapping="Wrap" />
            </StackPanel>
        </Flyout>
        </ResourceDictionary>
    </Page.Resources>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
            Gallery-style NavigationView: the pane hosts the status filters as
            data-bound menu items (icon-only in LeftCompact, labels + count InfoBadge
            when expanded via the built-in hamburger pane toggle). The footer Settings
            gear opens the in-app settings overlay. Content = action toolbar + table +
            details. The selection pill is drawn by NavigationView itself, so it never
            clips on the collapsed rail.
        -->
        <NavigationView
            x:Name="NavView"
            AutomationProperties.AutomationId="NavView"
            Grid.Row="0"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="True"
            OpenPaneLength="220"
            MenuItemsSource="{x:Bind ViewModel.Filters, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}"
            SelectionChanged="NavView_SelectionChanged"
            Visibility="{x:Bind local:MainPage.CollapsedIf(ViewModel.SettingsOpen), Mode=OneWay}">
            <NavigationView.MenuItemTemplate>
                <DataTemplate x:DataType="vm:FilterItemViewModel">
                    <NavigationViewItem
                        Content="{x:Bind Title}"
                        AutomationProperties.AutomationId="{x:Bind Key}">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="{x:Bind Glyph}" />
                        </NavigationViewItem.Icon>
                        <NavigationViewItem.InfoBadge>
                            <InfoBadge
                                Value="{x:Bind Count, Mode=OneWay}"
                                Visibility="{x:Bind local:MainPage.VisIf(HasCount), Mode=OneWay}" />
                        </NavigationViewItem.InfoBadge>
                    </NavigationViewItem>
                </DataTemplate>
            </NavigationView.MenuItemTemplate>

            <!-- Content: action toolbar + table + details -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Download action toolbar -->
                <CommandBar
                    Grid.Row="0"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left">
                    <AppBarButton
                        loc:Localize.Uid="ToolbarAddButton"
                        Command="{x:Bind ViewModel.AddDownloadCommand}"
                        AutomationProperties.AutomationId="AddDownloadButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </AppBarButton.Icon>
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="N" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton
                        loc:Localize.Uid="ToolbarResumeButton"
                        Command="{x:Bind ViewModel.ResumeSelectedCommand}"
                        IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                        AutomationProperties.AutomationId="ResumeSelectedButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE768;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        loc:Localize.Uid="ToolbarPauseButton"
                        Command="{x:Bind ViewModel.PauseSelectedCommand}"
                        IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                        AutomationProperties.AutomationId="PauseSelectedButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE769;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        loc:Localize.Uid="ToolbarRemoveButton"
                        Command="{x:Bind ViewModel.RemoveSelectedCommand}"
                        IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                        AutomationProperties.AutomationId="RemoveSelectedButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE74D;" />
                        </AppBarButton.Icon>
                        <AppBarButton.KeyboardAccelerators>
                            <!-- Scoped to the table: a window-global Delete would steal the key
                                 from every TextBox/NumberBox in the window (N15). -->
                            <KeyboardAccelerator Key="Delete" ScopeOwner="{x:Bind DownloadsList}" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarSeparator />
                    <!-- Turtle mode: one click swaps the global limits for the alternative pair
                         configured in Settings (and back). Mirrored in the tray menu. -->
                    <AppBarToggleButton
                        loc:Localize.Uid="ToolbarTurtleButton"
                        IsChecked="{x:Bind ViewModel.IsAltSpeed, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                        AutomationProperties.AutomationId="TurtleButton">
                        <AppBarToggleButton.Icon>
                            <FontIcon Glyph="&#xE708;" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                    <AppBarButton
                        loc:Localize.Uid="ToolbarMoreButton"
                        AutomationProperties.AutomationId="MoreButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE712;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem
                                    loc:Localize.Uid="MenuResumeAll"
                                    Command="{x:Bind ViewModel.ResumeAllCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                                    AutomationProperties.AutomationId="ResumeAllButton">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE768;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    loc:Localize.Uid="MenuPauseAll"
                                    Command="{x:Bind ViewModel.PauseAllCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                                    AutomationProperties.AutomationId="PauseAllButton">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE769;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    loc:Localize.Uid="MenuClearStopped"
                                    Command="{x:Bind ViewModel.ClearStoppedCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsEngineReady, Mode=OneWay}"
                                    AutomationProperties.AutomationId="ClearStoppedButton">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE894;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar>

                <!-- Table + details -->
                <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="232" MinHeight="128" MaxHeight="500" />
                </Grid.RowDefinitions>

                <!-- Table: header and rows share one horizontal scroller so they stay
                     aligned and scroll together when the columns overflow the width. -->
                <ScrollViewer
                    Grid.Row="0"
                    x:Name="TableScroll"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled"
                    SizeChanged="TableScroll_SizeChanged">
                    <Grid x:Name="TableContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                <!-- Column headers: dividers resize columns; right-click toggles which show.
                     The 8px top/bottom padding lives inside each header Button (not here) so a
                     button's hover/pressed highlight fills the full header-row height. -->
                <Grid
                    Grid.Row="0"
                    Padding="16,0,12,0"
                    ColumnSpacing="8"
                    Background="Transparent"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid.ContextFlyout>
                        <MenuFlyout>
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuSize" Tag="size" AutomationProperties.AutomationId="ColumnToggleSize" IsChecked="{x:Bind ViewModel.Columns.SizeVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuProgress" Tag="progress" AutomationProperties.AutomationId="ColumnToggleProgress" IsChecked="{x:Bind ViewModel.Columns.ProgressVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuStatus" Tag="status" AutomationProperties.AutomationId="ColumnToggleStatus" IsChecked="{x:Bind ViewModel.Columns.StatusVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuSeeds" Tag="seeds" AutomationProperties.AutomationId="ColumnToggleSeeds" IsChecked="{x:Bind ViewModel.Columns.SeedsVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuPeers" Tag="peers" AutomationProperties.AutomationId="ColumnTogglePeers" IsChecked="{x:Bind ViewModel.Columns.PeersVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuDown" Tag="down" AutomationProperties.AutomationId="ColumnToggleDown" IsChecked="{x:Bind ViewModel.Columns.DownVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuUp" Tag="up" AutomationProperties.AutomationId="ColumnToggleUp" IsChecked="{x:Bind ViewModel.Columns.UpVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuEta" Tag="eta" AutomationProperties.AutomationId="ColumnToggleEta" IsChecked="{x:Bind ViewModel.Columns.EtaVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuRatio" Tag="ratio" AutomationProperties.AutomationId="ColumnToggleRatio" IsChecked="{x:Bind ViewModel.Columns.RatioVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                            <ToggleMenuFlyoutItem loc:Localize.Uid="ColumnMenuUploaded" Tag="uploaded" AutomationProperties.AutomationId="ColumnToggleUploaded" IsChecked="{x:Bind ViewModel.Columns.UploadedVisible, Mode=OneWay}" Click="ColumnToggle_Click" />
                        </MenuFlyout>
                    </Grid.ContextFlyout>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.NameWidth, Mode=OneWay}" MinWidth="120" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.SizeWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.ProgressWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.StatusWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.SeedsWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.PeersWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.DownWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.UpWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.EtaWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.RatioWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="{x:Bind ViewModel.Columns.UploadedWidth, Mode=OneWay}" />
                    </Grid.ColumnDefinitions>
                    <Button Tag="name" AutomationProperties.AutomationId="HeaderName" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColName', 'name', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" />
                    <helpers:ResizeHandle Grid.Column="0" Tag="name" loc:Localize.Uid="ResizeHandleName" AutomationProperties.AutomationId="ResizeHandleName" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" />
                    <Button Grid.Column="1" Tag="size" AutomationProperties.AutomationId="HeaderSize" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColSize', 'size', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SizeVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="1" Tag="size" loc:Localize.Uid="ResizeHandleSize" AutomationProperties.AutomationId="ResizeHandleSize" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SizeVisible), Mode=OneWay}" />
                    <Button Grid.Column="2" Tag="progress" AutomationProperties.AutomationId="HeaderProgress" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColProgress', 'progress', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.ProgressVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="2" Tag="progress" loc:Localize.Uid="ResizeHandleProgress" AutomationProperties.AutomationId="ResizeHandleProgress" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.ProgressVisible), Mode=OneWay}" />
                    <Button Grid.Column="3" Tag="status" AutomationProperties.AutomationId="HeaderStatus" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColStatus', 'status', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.StatusVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="3" Tag="status" loc:Localize.Uid="ResizeHandleStatus" AutomationProperties.AutomationId="ResizeHandleStatus" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.StatusVisible), Mode=OneWay}" />
                    <Button Grid.Column="4" Tag="seeds" AutomationProperties.AutomationId="HeaderSeeds" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColSeeds', 'seeds', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SeedsVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="4" Tag="seeds" loc:Localize.Uid="ResizeHandleSeeds" AutomationProperties.AutomationId="ResizeHandleSeeds" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.SeedsVisible), Mode=OneWay}" />
                    <Button Grid.Column="5" Tag="peers" AutomationProperties.AutomationId="HeaderPeers" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColPeers', 'peers', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.PeersVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="5" Tag="peers" loc:Localize.Uid="ResizeHandlePeers" AutomationProperties.AutomationId="ResizeHandlePeers" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.PeersVisible), Mode=OneWay}" />
                    <Button Grid.Column="6" Tag="down" AutomationProperties.AutomationId="HeaderDown" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColDown', 'down', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.DownVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="6" Tag="down" loc:Localize.Uid="ResizeHandleDown" AutomationProperties.AutomationId="ResizeHandleDown" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.DownVisible), Mode=OneWay}" />
                    <Button Grid.Column="7" Tag="up" AutomationProperties.AutomationId="HeaderUp" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColUp', 'up', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UpVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="7" Tag="up" loc:Localize.Uid="ResizeHandleUp" AutomationProperties.AutomationId="ResizeHandleUp" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UpVisible), Mode=OneWay}" />
                    <Button Grid.Column="8" Tag="eta" AutomationProperties.AutomationId="HeaderEta" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColEta', 'eta', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.EtaVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="8" Tag="eta" loc:Localize.Uid="ResizeHandleEta" AutomationProperties.AutomationId="ResizeHandleEta" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.EtaVisible), Mode=OneWay}" />
                    <Button Grid.Column="9" Tag="ratio" AutomationProperties.AutomationId="HeaderRatio" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColRatio', 'ratio', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.RatioVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="9" Tag="ratio" loc:Localize.Uid="ResizeHandleRatio" AutomationProperties.AutomationId="ResizeHandleRatio" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.RatioVisible), Mode=OneWay}" />
                    <Button Grid.Column="10" Tag="uploaded" AutomationProperties.AutomationId="HeaderUploaded" Click="Header_Tapped" Content="{x:Bind local:MainPage.HeaderLabel('ColUploaded', 'uploaded', ViewModel.SortKey, ViewModel.SortDescending), Mode=OneWay}" Style="{StaticResource ColumnHeaderButtonStyle}" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UploadedVisible), Mode=OneWay}" />
                    <helpers:ResizeHandle Grid.Column="10" Tag="uploaded" loc:Localize.Uid="ResizeHandleUploaded" AutomationProperties.AutomationId="ResizeHandleUploaded" Style="{StaticResource ColumnResizeHandleStyle}" Resize="HeaderHandle_Resize" Visibility="{x:Bind local:MainPage.VisIf(ViewModel.Columns.UploadedVisible), Mode=OneWay}" />
                </Grid>

                <!-- Downloads table -->
                <ListView
                    x:Name="DownloadsList"
                    AutomationProperties.AutomationId="DownloadsList"
                    Grid.Row="1"
                    Padding="0"
                    SelectionMode="Extended"
                    SelectionChanged="DownloadsList_SelectionChanged"
                    ContainerContentChanging="ZebraList_ContainerContentChanging"
                    ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="16,0,12,0" />
                            <Setter Property="MinHeight" Value="36" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DownloadItemViewModel">
                            <Grid ColumnSpacing="8" DoubleTapped="Row_DoubleTapped" Background="Transparent" ToolTipService.ToolTip="{x:Bind StatusTooltip, Mode=OneWay}">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Text="{x:Bind PauseResumeText, Mode=OneWay}"
                                            Command="{x:Bind PauseResumeCommand}"
                                            IsEnabled="{x:Bind CanPauseResume, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE769;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem loc:Localize.Uid="RowMenuSpeedLimit" Click="SpeedLimit_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE896;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSubItem loc:Localize.Uid="RowMenuQueue" Visibility="{x:Bind local:MainPage.VisIf(IsQueued), Mode=OneWay}">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE8CB;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem loc:Localize.Uid="RowMenuQueueTop" Command="{x:Bind MoveToTopCommand}" AutomationProperties.AutomationId="QueueTopItem" />
                                            <MenuFlyoutItem loc:Localize.Uid="RowMenuQueueUp" Command="{x:Bind MoveUpCommand}" AutomationProperties.AutomationId="QueueUpItem" />
                                            <MenuFlyoutItem loc:Localize.Uid="RowMenuQueueDown" Command="{x:Bind MoveDownCommand}" AutomationProperties.AutomationId="QueueDownItem" />
                                            <MenuFlyoutItem loc:Localize.Uid="RowMenuQueueBottom" Command="{x:Bind MoveToBottomCommand}" AutomationProperties.AutomationId="QueueBottomItem" />
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutItem loc:Localize.Uid="RowMenuOpenFolder" Command="{x:Bind OpenFolderCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE838;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            loc:Localize.Uid="RowMenuSetLocation"
                                            Command="{x:Bind SetLocationCommand}"
                                            Visibility="{x:Bind local:MainPage.VisIf(HasMagnet), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8DE;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            loc:Localize.Uid="RowMenuCopyMagnet"
                                            Command="{x:Bind CopyMagnetCommand}"
                                            Visibility="{x:Bind HasMagnet, Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE71B;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            loc:Localize.Uid="RowMenuRecheck"
                                            Command="{x:Bind RecheckCommand}"
                                            Visibility="{x:Bind local:MainPage.VisIf(HasMagnet), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE72C;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem loc:Localize.Uid="RowMenuRemove" Command="{x:Bind RemoveCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem loc:Localize.Uid="RowMenuRemoveWithFiles" Command="{x:Bind RemoveWithFilesCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74E;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{x:Bind Columns.NameWidth, Mode=OneWay}" MinWidth="120" />
                                    <ColumnDefinition Width="{x:Bind Columns.SizeWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.ProgressWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.StatusWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.SeedsWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.PeersWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.DownWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.UpWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.EtaWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.RatioWidth, Mode=OneWay}" />
                                    <ColumnDefinition Width="{x:Bind Columns.UploadedWidth, Mode=OneWay}" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon
                                        Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                        FontSize="13"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Text="{x:Bind Name, Mode=OneWay}"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind SizeText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.SizeVisible), Mode=OneWay}" />
                                <Grid Grid.Column="2" VerticalAlignment="Center" ColumnSpacing="8" Visibility="{x:Bind local:MainPage.VisIf(Columns.ProgressVisible), Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar
                                        Value="{x:Bind Progress, Mode=OneWay}"
                                        Maximum="100"
                                        MinHeight="8"
                                        VerticalAlignment="Center"
                                        IsIndeterminate="{x:Bind IsProgressIndeterminate, Mode=OneWay}"
                                        ShowError="{x:Bind IsError, Mode=OneWay}"
                                        ShowPaused="{x:Bind IsPaused, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind ProgressText, Mode=OneWay}"
                                        Style="{StaticResource CellTextStyle}"
                                        TextAlignment="Right" />
                                </Grid>
                                <Grid Grid.Column="3" Visibility="{x:Bind local:MainPage.VisIf(Columns.StatusVisible), Mode=OneWay}">
                                    <!-- Two themed status cells toggled by IsError so the colour stays
                                         {ThemeResource}-driven and updates on Light/Dark switch: normal rows
                                         keep the default themed foreground, error rows show the critical brush. -->
                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.CollapsedIf(IsError), Mode=OneWay}" />
                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="{x:Bind local:MainPage.VisIf(IsError), Mode=OneWay}" />
                                </Grid>
                                <TextBlock Grid.Column="4" Text="{x:Bind SeedsText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.SeedsVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="5" Text="{x:Bind PeersText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.PeersVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="6" Text="{x:Bind DownSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.DownVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="7" Text="{x:Bind UpSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.UpVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="8" Text="{x:Bind EtaText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.EtaVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="9" Text="{x:Bind RatioText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.RatioVisible), Mode=OneWay}" />
                                <TextBlock Grid.Column="10" Text="{x:Bind UploadedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" Visibility="{x:Bind local:MainPage.VisIf(Columns.UploadedVisible), Mode=OneWay}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                    </Grid>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
                    <FontIcon
                        Glyph="&#xE896;"
                        FontSize="44"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock
                        loc:Localize.Uid="EmptyStateTitle"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        loc:Localize.Uid="EmptyStateHint"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <toolkit:GridSplitter
                    Grid.Row="1"
                    loc:Localize.Uid="DetailsSplitter"
                    AutomationProperties.AutomationId="DetailsSplitter"
                    Height="8"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Auto" />

                <!-- Details pane: wrapped in a WinUI-style card surface (rounded,
                     card fill + stroke, 16px inner padding) that floats over the
                     window's Mica with a 16px outer margin from the table above. -->
                <Border
                    Grid.Row="2"
                    Margin="16,8,16,16"
                    Padding="16"
                    CornerRadius="{StaticResource OverlayCornerRadius}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Details tabs: connected Segmented (pill/box) selector. SelectedIndex is a
                         TwoWay DP bound straight to the VM's DetailsTabIndex (0=General, 1=Files,
                         2=Peers); the panels below toggle off that same index. Labels reuse the
                         existing DetailsTab*.Text resources; AutomationIds match the old SelectorBar. -->
                    <toolkit:Segmented
                        x:Name="DetailsTabs"
                        Margin="0,0,0,4"
                        SelectedIndex="{x:Bind ViewModel.DetailsTabIndex, Mode=TwoWay}">
                        <toolkit:SegmentedItem
                            AutomationProperties.AutomationId="DetailsTabGeneral"
                            Content="{x:Bind local:MainPage.TabLabel('DetailsTabGeneral')}" />
                        <toolkit:SegmentedItem
                            AutomationProperties.AutomationId="DetailsTabFiles"
                            Content="{x:Bind local:MainPage.TabLabel('DetailsTabFiles')}" />
                        <toolkit:SegmentedItem
                            AutomationProperties.AutomationId="DetailsTabPeers"
                            Content="{x:Bind local:MainPage.TabLabel('DetailsTabPeers')}" />
                        <toolkit:SegmentedItem
                            AutomationProperties.AutomationId="DetailsTabTrackers"
                            Content="{x:Bind local:MainPage.TabLabel('DetailsTabTrackers')}" />
                    </toolkit:Segmented>

                    <!-- No selection placeholder -->
                    <TextBlock
                        Grid.Row="1"
                        loc:Localize.Uid="DetailsNoSelection"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind local:MainPage.CollapsedIf(ViewModel.HasSelection), Mode=OneWay}" />

                    <!-- General -->
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 0, ViewModel.HasSelection), Mode=OneWay}">
                        <Grid Padding="0,8,0,0" RowSpacing="4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock loc:Localize.Uid="DetailLabelSavePath" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="5" Text="{x:Bind ViewModel.DetSavePath, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" loc:Localize.Uid="DetailLabelSize" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.DetSize, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" loc:Localize.Uid="DetailLabelStatus" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind ViewModel.DetStatus, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" loc:Localize.Uid="DetailLabelSpeed" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="{x:Bind ViewModel.DetSpeed, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="2" loc:Localize.Uid="DetailLabelHash" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Text="{x:Bind ViewModel.DetHash, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" loc:Localize.Uid="DetailLabelRatio" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.DetRatio, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" loc:Localize.Uid="DetailLabelUploaded" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{x:Bind ViewModel.DetUploaded, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="4" loc:Localize.Uid="DetailLabelConnections" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="5" Text="{x:Bind ViewModel.DetConnections, Mode=OneWay}" Style="{StaticResource DetailValueStyle}" />
                        </Grid>
                    </ScrollViewer>

                    <!-- Files: torrent folder tree (same structure as the add window) with
                         per-file download checkboxes, size and live progress. Folders show
                         aggregate size/progress and a three-state checkbox that cascades. -->
                    <TreeView
                        x:Name="FilesTree"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        SelectionMode="None"
                        Loaded="FilesTree_Loaded"
                        ItemsSource="{x:Bind ViewModel.FileTree, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 1, ViewModel.HasSelection), Mode=OneWay}">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileTreeNodeViewModel">
                                <TreeViewItem
                                    ItemsSource="{x:Bind Children}"
                                    IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                    HorizontalContentAlignment="Stretch">
                                    <Grid ColumnSpacing="8" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox
                                            loc:Localize.Uid="FileTreeDownloadCheckBox"
                                            MinWidth="0"
                                            VerticalAlignment="Center"
                                            IsThreeState="{x:Bind IsFolder}"
                                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                        <FontIcon
                                            Grid.Column="1"
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="{x:Bind local:MainPage.FileNodeGlyph(IsFolder)}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Name, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind SizeText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" HorizontalAlignment="Right" />
                                        <ProgressBar Grid.Column="4" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind ProgressText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    </Grid>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Peers -->
                    <ListView
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Padding="0"
                        SelectionMode="None"
                        ItemsSource="{x:Bind ViewModel.Peers, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 2, ViewModel.HasSelection), Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Padding" Value="0,0,12,0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PeerRowViewModel">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Address, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Kind, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind DownSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind UpSpeedText, Mode=OneWay}" Style="{StaticResource CellTextStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Trackers -->
                    <Grid
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        RowSpacing="8"
                        Visibility="{x:Bind local:MainPage.TabVisible(ViewModel.DetailsTabIndex, 3, ViewModel.HasSelection), Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Button loc:Localize.Uid="AddTrackersButton" AutomationProperties.AutomationId="AddTrackersButton" HorizontalAlignment="Left">
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Width="360" Spacing="8">
                                        <TextBox
                                            x:Name="AddTrackersBox"
                                            loc:Localize.Uid="AddTrackersBox"
                                            AutomationProperties.AutomationId="AddTrackersBox"
                                            AcceptsReturn="True"
                                            Height="120"
                                            TextWrapping="Wrap" />
                                        <Button
                                            loc:Localize.Uid="ConfirmAddTrackersButton"
                                            AutomationProperties.AutomationId="ConfirmAddTrackersButton"
                                            Style="{StaticResource AccentButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Click="AddTrackers_Click" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <ListView
                            Grid.Row="1"
                            Padding="0"
                            SelectionMode="None"
                            ItemsSource="{x:Bind ViewModel.Trackers, Mode=OneWay}"
                            ContainerContentChanging="ZebraList_ContainerContentChanging">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="32" />
                                    <Setter Property="Padding" Value="8,0,12,0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}" Style="{StaticResource CellTextStyle}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                    </Grid>
                </Border>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Settings page: full width of the window, on the same Mica backdrop. -->
        <views:SettingsView
            x:Name="SettingsPage"
            Grid.Row="0"
            Closed="SettingsPage_Closed"
            Visibility="{x:Bind local:MainPage.VisIf(ViewModel.SettingsOpen), Mode=OneWay}" />

        <!-- Engine failure surface -->
        <InfoBar
            Grid.Row="0"
            loc:Localize.Uid="EngineErrorInfoBar"
            VerticalAlignment="Bottom"
            Margin="12"
            Severity="Error"
            Message="{x:Bind ViewModel.EngineErrorText, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.HasEngineError, Mode=OneWay}" />

        <!-- Transient notices for drag-and-drop adds (errors, duplicates). Set from code-behind. -->
        <InfoBar
            Grid.Row="0"
            x:Name="AddNoticeBar"
            AutomationProperties.AutomationId="AddNoticeBar"
            VerticalAlignment="Top"
            Margin="12"
            IsOpen="False"
            IsClosable="True" />

        <!-- Status bar -->
        <Grid
            Grid.Row="1"
            Padding="16,8"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xEC05;"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    AutomationProperties.AutomationId="EngineStatusText"
                    Text="{x:Bind ViewModel.EngineStatusText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
                <TextBlock
                    AutomationProperties.AutomationId="CountsText"
                    Text="{x:Bind ViewModel.CountsText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
            <!-- The live speeds double as the statistics button: clicking opens the
                 session/all-time totals flyout (filled on open — no per-tick cost). -->
            <Button
                Grid.Column="1"
                loc:Localize.Uid="StatsButton"
                AutomationProperties.AutomationId="StatsButton"
                Background="Transparent"
                BorderThickness="0"
                Padding="8,2"
                VerticalAlignment="Center">
                <TextBlock
                    AutomationProperties.AutomationId="GlobalSpeedText"
                    Text="{x:Bind ViewModel.GlobalSpeedText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
                <Button.Flyout>
                    <Flyout Opened="StatsFlyout_Opened">
                        <Grid ColumnSpacing="20" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.ColumnSpan="3" loc:Localize.Uid="StatsTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" loc:Localize.Uid="StatsColSession" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" loc:Localize.Uid="StatsColAllTime" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
