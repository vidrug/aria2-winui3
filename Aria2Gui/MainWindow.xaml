<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Aria2Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Aria2Gui"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Aria2Gui">
            <TitleBar.IconSource>
                <!-- Decode the crisp 32px .ico frame in PHYSICAL pixels: the title-bar slot
                     is ~16-32px across 100-200% DPI, so the icon is always a clean downscale
                     (never an upscale, and never a fractional-DPI frame mismatch) → sharp. -->
                <ImageIconSource>
                    <ImageIconSource.ImageSource>
                        <BitmapImage UriSource="ms-appx:///Assets/AppIcon.ico" DecodePixelType="Physical" DecodePixelWidth="32" DecodePixelHeight="32" />
                    </ImageIconSource.ImageSource>
                </ImageIconSource>
            </TitleBar.IconSource>
        </TitleBar>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
