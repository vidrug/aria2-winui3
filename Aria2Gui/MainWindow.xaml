<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Aria2Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Aria2Gui"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Aria2Gui">
            <!-- Plain ImageIconSource like the WinUI 3 Gallery (no DecodePixelWidth, the
                 framework picks the frame per DPI), but pointed at a small-frames-only .ico
                 (16-48px) so it can never pick the 256px frame and downscale it to mush —
                 it always renders from a sharp small frame, crisp at every display scale. -->
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/AppIconSmall.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
