<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Aria2Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aria2Gui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Aria2Gui"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Aria2Gui">
            <TitleBar.IconSource>
                <!-- Decode the crisp 64px .ico frame in PHYSICAL pixels. The title-bar icon
                     slot is far smaller than 64px at every DPI (≈16px at 100% … ≈48px at
                     300%), so the bitmap is ALWAYS downscaled from a sharp source — never
                     upscaled and never a fractional-DPI frame mismatch — so it stays crisp
                     at all display scales. -->
                <ImageIconSource>
                    <ImageIconSource.ImageSource>
                        <BitmapImage UriSource="ms-appx:///Assets/AppIcon.ico" DecodePixelType="Physical" DecodePixelWidth="64" DecodePixelHeight="64" />
                    </ImageIconSource.ImageSource>
                </ImageIconSource>
            </TitleBar.IconSource>
        </TitleBar>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
