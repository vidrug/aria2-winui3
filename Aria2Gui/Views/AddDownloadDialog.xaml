<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Aria2Gui.Views.AddDownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="using:Aria2Gui.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Новая загрузка"
    PrimaryButtonText="Добавить"
    CloseButtonText="Отмена"
    DefaultButton="Primary"
    PrimaryButtonClick="OnAddClick">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
    </ContentDialog.Resources>

    <StackPanel Spacing="12" MinWidth="600">
        <TextBox
            x:Name="UrlsBox"
            AutomationProperties.AutomationId="UrlsBox"
            Header="Ссылки HTTP/FTP или magnet — по одной в строке"
            PlaceholderText="magnet:?xt=urn:btih:…"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="88"
            ScrollViewer.VerticalScrollBarVisibility="Auto" />

        <!-- Save destination -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="DirBox"
                AutomationProperties.AutomationId="AddDirBox"
                Header="Папка сохранения"
                IsReadOnly="True" />
            <Button
                AutomationProperties.AutomationId="AddBrowseFolderButton"
                Grid.Column="1"
                Content="Обзор…"
                VerticalAlignment="Bottom"
                Click="OnBrowseFolderClick" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                AutomationProperties.AutomationId="PickTorrentButton"
                Content="Выбрать .torrent-файл…"
                Click="OnPickTorrentClick" />
            <TextBlock
                x:Name="TorrentFileName"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextTrimming="CharacterEllipsis"
                MaxWidth="240" />
        </StackPanel>

        <!-- Torrent contents (appears after picking a .torrent) -->
        <StackPanel x:Name="TorrentFilesPanel" Spacing="8" Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Text="Файлы торрента"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    VerticalAlignment="Center" />
                <Button
                    AutomationProperties.AutomationId="SelectAllFilesButton"
                    Grid.Column="1"
                    Content="Выбрать все"
                    Click="OnSelectAllClick" />
                <Button
                    AutomationProperties.AutomationId="DeselectAllFilesButton"
                    Grid.Column="2"
                    Content="Снять выбор"
                    Click="OnDeselectAllClick" />
            </Grid>
            <Border
                BorderThickness="1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Height="248">
                <!-- Long file names scroll horizontally instead of clipping. -->
                <TreeView
                    x:Name="FileTree"
                    AutomationProperties.AutomationId="TorrentFileTree"
                    SelectionMode="Multiple"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollMode="Enabled">
                    <!-- In unbound mode the template's data root is the TreeViewNode,
                         whose Content carries our TorrentNodeContent. -->
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="muxc:TreeViewNode">
                            <TextBlock Text="{x:Bind ((vm:TorrentNodeContent)Content).Label, Mode=OneTime}" TextWrapping="NoWrap" />
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </StackPanel>

        <InfoBar
            x:Name="ErrorBar"
            Severity="Error"
            IsOpen="False"
            IsClosable="False" />
    </StackPanel>
</ContentDialog>
