<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Aria2Gui.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:Aria2Gui.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- WinUI Gallery look: a flat back arrow in the top-left corner, page title
             in the content below. A standard Button (not NavigationBackButtonNormalStyle,
             whose hover highlight renders square in this SDK) gives a rounded hover via
             the default template's ControlCornerRadius and a reliable direct Click. -->
        <Button
            Grid.Row="0"
            loc:Localize.Uid="SettingsBackButton"
            AutomationProperties.AutomationId="SettingsBackButton"
            Width="40"
            Height="40"
            Padding="0"
            Margin="4,4,0,0"
            Background="Transparent"
            BorderThickness="0"
            Click="OnBackClick">
            <FontIcon Glyph="&#xE72B;" FontSize="16" />
        </Button>

        <NavigationView
            x:Name="SettingsNav"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            OpenPaneLength="240"
            SelectionChanged="OnSectionChanged">
            <NavigationView.Resources>
                <!-- Transparent surfaces so the window's Mica backdrop shows through,
                     matching the rest of the app instead of a flat grey panel. Scoped
                     to Light/Dark only — in High Contrast (Mica is off) an empty HC
                     dictionary keeps the opaque system pane fill and visible divider. -->
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Light">
                            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="HighContrast" />
                    </ResourceDictionary.ThemeDictionaries>
                    <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
                </ResourceDictionary>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem loc:Localize.Uid="NavGeneral" Tag="general" IsSelected="True" AutomationProperties.AutomationId="NavGeneral">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem loc:Localize.Uid="NavConnection" Tag="connection" AutomationProperties.AutomationId="NavConnection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE968;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem loc:Localize.Uid="NavFiles" Tag="files" AutomationProperties.AutomationId="NavFiles">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="BitTorrent" Tag="bt" AutomationProperties.AutomationId="NavBt">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem loc:Localize.Uid="NavAdvanced" Tag="advanced" AutomationProperties.AutomationId="NavAdvanced">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE712;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem loc:Localize.Uid="NavAbout" Tag="about" AutomationProperties.AutomationId="NavAbout">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                Padding="24,8,24,16">
                <!-- Grid gives the panel the full content width so the cards stretch
                     to MaxWidth and centre (a Center StackPanel would shrink to fit). -->
                <Grid HorizontalAlignment="Stretch">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch">

                    <TextBlock loc:Localize.Uid="SettingsTitle" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,20" />

                    <!-- ===== Основные ===== -->
                    <StackPanel x:Name="GeneralPanel" Spacing="4">
                        <tk:SettingsCard loc:Localize.Uid="DownloadFolderCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE838;" />
                            </tk:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="DirText" AutomationProperties.AutomationId="DownloadDirText" VerticalAlignment="Center" MaxWidth="280" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button loc:Localize.Uid="BrowseFolderButton" AutomationProperties.AutomationId="BrowseFolderButton" Click="OnBrowseClick" />
                            </StackPanel>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="DownLimitCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE896;" />
                            </tk:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <NumberBox x:Name="DownLimitBox" AutomationProperties.AutomationId="DownLimitBox" Minimum="0" MinWidth="120" SmallChange="1" SpinButtonPlacementMode="Compact" VerticalAlignment="Center" />
                                <ComboBox x:Name="DownLimitUnitBox" AutomationProperties.AutomationId="DownLimitUnitBox" MinWidth="72" VerticalAlignment="Center" SelectedValuePath="Tag">
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitByte" Tag="B" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitKByte" Tag="KB" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitKBit" Tag="Kb" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitMByte" Tag="MB" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitMBit" Tag="Mb" />
                                </ComboBox>
                            </StackPanel>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="UpLimitCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE898;" />
                            </tk:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <NumberBox x:Name="UpLimitBox" AutomationProperties.AutomationId="UpLimitBox" Minimum="0" MinWidth="120" SmallChange="1" SpinButtonPlacementMode="Compact" VerticalAlignment="Center" />
                                <ComboBox x:Name="UpLimitUnitBox" AutomationProperties.AutomationId="UpLimitUnitBox" MinWidth="72" VerticalAlignment="Center" SelectedValuePath="Tag">
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitByte" Tag="B" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitKByte" Tag="KB" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitKBit" Tag="Kb" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitMByte" Tag="MB" />
                                    <ComboBoxItem loc:Localize.Uid="SpeedUnitMBit" Tag="Mb" />
                                </ComboBox>
                            </StackPanel>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="ConcurrentCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE71D;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="ConcurrentBox" AutomationProperties.AutomationId="ConcurrentBox" Minimum="1" Maximum="50" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="ConnectionsCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE968;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="ConnectionsBox" AutomationProperties.AutomationId="ConnectionsBox" Minimum="1" Maximum="16" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="PreventSleepCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEC46;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="PreventSleepToggle" AutomationProperties.AutomationId="PreventSleepToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="ThemeCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE790;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ComboBox x:Name="ThemeBox" AutomationProperties.AutomationId="ThemeBox" MinWidth="180">
                                <ComboBoxItem loc:Localize.Uid="ThemeSystemItem" Tag="Default" />
                                <ComboBoxItem loc:Localize.Uid="ThemeLightItem" Tag="Light" />
                                <ComboBoxItem loc:Localize.Uid="ThemeDarkItem" Tag="Dark" />
                            </ComboBox>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="LanguageCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE774;" />
                            </tk:SettingsCard.HeaderIcon>
                            <!-- Language names are autonyms (shown the same regardless of UI language). -->
                            <ComboBox x:Name="LanguageBox" AutomationProperties.AutomationId="LanguageBox" MinWidth="200">
                                <ComboBoxItem loc:Localize.Uid="LanguageSystemItem" Tag="" />
                                <ComboBoxItem Content="English" Tag="en-US" />
                                <ComboBoxItem Content="Русский" Tag="ru" />
                                <ComboBoxItem Content="Español" Tag="es" />
                                <ComboBoxItem Content="Deutsch" Tag="de" />
                                <ComboBoxItem Content="Français" Tag="fr" />
                                <ComboBoxItem Content="Português (Brasil)" Tag="pt-BR" />
                                <ComboBoxItem Content="Italiano" Tag="it" />
                                <ComboBoxItem Content="中文（简体）" Tag="zh-Hans" />
                                <ComboBoxItem Content="日本語" Tag="ja" />
                                <ComboBoxItem Content="Українська" Tag="uk" />
                                <ComboBoxItem Content="Polski" Tag="pl" />
                                <ComboBoxItem Content="Türkçe" Tag="tr" />
                            </ComboBox>
                        </tk:SettingsCard>
                        <!-- The UI language only changes on relaunch; offer it instead of forcing a restart. -->
                        <InfoBar
                            x:Name="LanguageRestartBar"
                            loc:Localize.Uid="LanguageRestartBar"
                            Severity="Informational"
                            IsOpen="False"
                            IsClosable="False"
                            Margin="0,4,0,0">
                            <InfoBar.ActionButton>
                                <Button loc:Localize.Uid="LanguageRestartButton" AutomationProperties.AutomationId="LanguageRestartButton" Click="OnRestartForLanguage" />
                            </InfoBar.ActionButton>
                        </InfoBar>
                    </StackPanel>

                    <!-- ===== Подключение ===== -->
                    <StackPanel x:Name="ConnectionPanel" Spacing="4" Visibility="Collapsed">
                        <!-- Proxy as an expander so its credentials live with the proxy URL. -->
                        <tk:SettingsExpander loc:Localize.Uid="ProxyCard">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE968;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <TextBox x:Name="ProxyBox" loc:Localize.Uid="ProxyBox" AutomationProperties.AutomationId="ProxyBox" MinWidth="300" />
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard loc:Localize.Uid="ProxyUserCard">
                                    <TextBox x:Name="ProxyUserBox" AutomationProperties.AutomationId="ProxyUserBox" MinWidth="220" />
                                </tk:SettingsCard>
                                <tk:SettingsCard loc:Localize.Uid="ProxyPasswdCard">
                                    <PasswordBox x:Name="ProxyPasswdBox" AutomationProperties.AutomationId="ProxyPasswdBox" MinWidth="220" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>
                        <tk:SettingsCard loc:Localize.Uid="CheckCertCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE72E;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="CheckCertToggle" loc:Localize.Uid="CheckCertToggle" AutomationProperties.AutomationId="CheckCertToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="TimeoutCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE916;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="TimeoutBox" AutomationProperties.AutomationId="TimeoutBox" Minimum="1" Maximum="600" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="ConnectTimeoutCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE839;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="ConnectTimeoutBox" AutomationProperties.AutomationId="ConnectTimeoutBox" Minimum="1" Maximum="600" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="MaxTriesCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE72C;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="MaxTriesBox" AutomationProperties.AutomationId="MaxTriesBox" Minimum="0" Maximum="100" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="RetryWaitCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE823;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="RetryWaitBox" AutomationProperties.AutomationId="RetryWaitBox" Minimum="0" Maximum="600" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="MinSplitSizeCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="MinSplitSizeBox" AutomationProperties.AutomationId="MinSplitSizeBox" MinWidth="148" PlaceholderText="20M" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="UserAgentCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE7C1;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="UserAgentBox" loc:Localize.Uid="UserAgentBox" AutomationProperties.AutomationId="UserAgentBox" MinWidth="300" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="LowestSpeedLimitCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE9D9;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="LowestSpeedLimitBox" AutomationProperties.AutomationId="LowestSpeedLimitBox" MinWidth="148" PlaceholderText="0" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="MinTlsCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE72E;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ComboBox x:Name="MinTlsBox" AutomationProperties.AutomationId="MinTlsBox" MinWidth="148">
                                <ComboBoxItem Content="TLS 1.1" Tag="TLSv1.1" />
                                <ComboBoxItem Content="TLS 1.2" Tag="TLSv1.2" />
                                <ComboBoxItem Content="TLS 1.3" Tag="TLSv1.3" />
                            </ComboBox>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="DisableIpv6Card">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE968;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="DisableIpv6Toggle" loc:Localize.Uid="DisableIpv6Toggle" AutomationProperties.AutomationId="DisableIpv6Toggle" />
                        </tk:SettingsCard>
                        <tk:SettingsExpander loc:Localize.Uid="AuthExpander">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE8D7;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard loc:Localize.Uid="HttpUserCard">
                                    <TextBox x:Name="HttpUserBox" AutomationProperties.AutomationId="HttpUserBox" MinWidth="220" />
                                </tk:SettingsCard>
                                <tk:SettingsCard loc:Localize.Uid="HttpPasswdCard">
                                    <PasswordBox x:Name="HttpPasswdBox" AutomationProperties.AutomationId="HttpPasswdBox" MinWidth="220" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>
                    </StackPanel>

                    <!-- ===== Файлы ===== -->
                    <StackPanel x:Name="FilesPanel" Spacing="4" Visibility="Collapsed">
                        <tk:SettingsCard loc:Localize.Uid="FileAllocCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEDA2;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ComboBox x:Name="FileAllocBox" AutomationProperties.AutomationId="FileAllocBox" MinWidth="180">
                                <ComboBoxItem loc:Localize.Uid="FileAllocAutoItem" Tag="auto" />
                                <ComboBoxItem loc:Localize.Uid="FileAllocNoneItem" Tag="none" />
                                <ComboBoxItem loc:Localize.Uid="FileAllocPreallocItem" Tag="prealloc" />
                                <ComboBoxItem loc:Localize.Uid="FileAllocTruncItem" Tag="trunc" />
                                <ComboBoxItem loc:Localize.Uid="FileAllocFallocItem" Tag="falloc" />
                            </ComboBox>
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="AllowOverwriteCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE74D;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="AllowOverwriteToggle" loc:Localize.Uid="AllowOverwriteToggle" AutomationProperties.AutomationId="AllowOverwriteToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="AutoRenameCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8AC;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="AutoRenameToggle" loc:Localize.Uid="AutoRenameToggle" AutomationProperties.AutomationId="AutoRenameToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="DiskCacheCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEDA2;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="DiskCacheBox" AutomationProperties.AutomationId="DiskCacheBox" MinWidth="148" PlaceholderText="16M" />
                        </tk:SettingsCard>
                    </StackPanel>

                    <!-- ===== BitTorrent ===== -->
                    <StackPanel x:Name="BtPanel" Spacing="4" Visibility="Collapsed">
                        <!-- One-click privacy preset: force encryption + turn off the public peer-
                             discovery mechanisms (DHT/PEX/LPD). Flips the individual toggles below so
                             the change is visible; the engine restart applies it on leaving the page. -->
                        <tk:SettingsCard loc:Localize.Uid="PrivacyModeCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE72E;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="PrivacyToggle" loc:Localize.Uid="PrivacyToggle" AutomationProperties.AutomationId="PrivacyToggle" Toggled="OnPrivacyToggled" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="ListenPortCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE945;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="ListenPortBox" AutomationProperties.AutomationId="ListenPortBox" Minimum="0" Maximum="65535" MinWidth="148" SpinButtonPlacementMode="Hidden" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="DhtCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE71B;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="DhtToggle" loc:Localize.Uid="DhtToggle" AutomationProperties.AutomationId="DhtToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="PexCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8AF;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="PexToggle" loc:Localize.Uid="PexToggle" AutomationProperties.AutomationId="PexToggle" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="LpdCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE839;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="LpdToggle" loc:Localize.Uid="LpdToggle" AutomationProperties.AutomationId="LpdToggle" />
                        </tk:SettingsCard>
                        <!-- Encryption as a SettingsExpander: the toggle sits in the header and
                             the encryption-level choice (a parameter of this setting) expands
                             out of it. Expanded automatically while encryption is required. -->
                        <tk:SettingsExpander x:Name="CryptoExpander" loc:Localize.Uid="CryptoCard">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE72E;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <ToggleSwitch x:Name="CryptoToggle" loc:Localize.Uid="CryptoToggle" AutomationProperties.AutomationId="CryptoToggle" Toggled="OnCryptoToggled" />
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard loc:Localize.Uid="CryptoLevelCard" ContentAlignment="Vertical" HorizontalContentAlignment="Stretch">
                                    <tk:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE8D7;" />
                                    </tk:SettingsCard.HeaderIcon>
                                    <RadioButtons x:Name="CryptoLevelRadio" AutomationProperties.AutomationId="CryptoLevelRadio" HorizontalAlignment="Left">
                                <RadioButton AutomationProperties.AutomationId="CryptoLevelPlain">
                                    <StackPanel Spacing="4">
                                        <TextBlock loc:Localize.Uid="CryptoLevelPlainTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock
                                            loc:Localize.Uid="CryptoLevelPlainDesc"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            MaxWidth="560"
                                            HorizontalAlignment="Left" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton AutomationProperties.AutomationId="CryptoLevelArc4">
                                    <StackPanel Spacing="4">
                                        <TextBlock loc:Localize.Uid="CryptoLevelArc4Title" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock
                                            loc:Localize.Uid="CryptoLevelArc4Desc"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            MaxWidth="560"
                                            HorizontalAlignment="Left" />
                                    </StackPanel>
                                </RadioButton>
                                    </RadioButtons>
                                </tk:SettingsCard>
                                <tk:SettingsCard loc:Localize.Uid="ForceEncryptionCard">
                                    <tk:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE785;" />
                                    </tk:SettingsCard.HeaderIcon>
                                    <ToggleSwitch x:Name="ForceEncryptionToggle" loc:Localize.Uid="ForceEncryptionToggle" AutomationProperties.AutomationId="ForceEncryptionToggle" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>
                        <tk:SettingsCard loc:Localize.Uid="MaxPeersCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE716;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="PeersBox" AutomationProperties.AutomationId="PeersBox" Minimum="0" Maximum="1000" MinWidth="148" SpinButtonPlacementMode="Hidden" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="BtMaxOpenFilesCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="BtMaxOpenFilesBox" AutomationProperties.AutomationId="BtMaxOpenFilesBox" Minimum="1" Maximum="10000" MinWidth="148" SpinButtonPlacementMode="Hidden" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="BtPeerSpeedCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE9D9;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="BtPeerSpeedBox" AutomationProperties.AutomationId="BtPeerSpeedBox" MinWidth="148" PlaceholderText="50K" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="BtStopTimeoutCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE916;" />
                            </tk:SettingsCard.HeaderIcon>
                            <NumberBox x:Name="BtStopTimeoutBox" AutomationProperties.AutomationId="BtStopTimeoutBox" Minimum="0" Maximum="86400" MinWidth="148" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard loc:Localize.Uid="BtDetachSeedCard">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8AF;" />
                            </tk:SettingsCard.HeaderIcon>
                            <ToggleSwitch x:Name="BtDetachSeedToggle" loc:Localize.Uid="BtDetachSeedToggle" AutomationProperties.AutomationId="BtDetachSeedToggle" />
                        </tk:SettingsCard>
                        <!-- Seeding as a SettingsExpander: the mode (ratio / time / off) is the header
                             control and its value (ratio or minutes) expands out as a parameter,
                             mirroring the encryption expander. The value card's header/units adapt
                             to the mode in code; "off" collapses it. -->
                        <tk:SettingsExpander x:Name="SeedExpander" loc:Localize.Uid="SeedCard">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE898;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <ComboBox x:Name="SeedModeBox" AutomationProperties.AutomationId="SeedModeBox" MinWidth="180">
                                <ComboBoxItem loc:Localize.Uid="SeedModeRatioItem" Tag="ratio" />
                                <ComboBoxItem loc:Localize.Uid="SeedModeTimeItem" Tag="time" />
                                <ComboBoxItem loc:Localize.Uid="SeedModeOffItem" Tag="off" />
                            </ComboBox>
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard x:Name="SeedValueCard">
                                    <tk:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE9D5;" />
                                    </tk:SettingsCard.HeaderIcon>
                                    <NumberBox x:Name="SeedValueBox" AutomationProperties.AutomationId="SeedValueBox" Minimum="0" Maximum="525600" MinWidth="148" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>
                        <tk:SettingsExpander loc:Localize.Uid="TrackersExpander">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE774;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard ContentAlignment="Vertical">
                                    <TextBox x:Name="TrackersBox" loc:Localize.Uid="TrackersBox" AutomationProperties.AutomationId="TrackersBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>
                        <InfoBar loc:Localize.Uid="BtRestartInfoBar" Severity="Informational" IsOpen="True" IsClosable="False" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- ===== Дополнительно ===== -->
                    <StackPanel x:Name="AdvancedPanel" Spacing="4" Visibility="Collapsed">
                        <tk:SettingsCard loc:Localize.Uid="ExtraOptionsCard" ContentAlignment="Vertical">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE713;" />
                            </tk:SettingsCard.HeaderIcon>
                            <TextBox x:Name="ExtraOptionsBox" AutomationProperties.AutomationId="ExtraOptionsBox" PlaceholderText="bt-request-peer-speed-limit=100K&#x0a;bt-stop-timeout=0" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" FontFamily="{StaticResource MonospaceFontFamily}" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </tk:SettingsCard>
                        <InfoBar loc:Localize.Uid="AdvancedInfoBar" Severity="Informational" IsOpen="True" IsClosable="False" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- ===== About ===== -->
                    <StackPanel x:Name="AboutPanel" Spacing="4" Visibility="Collapsed">
                        <tk:SettingsCard x:Name="AppInfoCard" Header="Aria2Gui">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE946;" />
                            </tk:SettingsCard.HeaderIcon>
                            <HyperlinkButton AutomationProperties.AutomationId="AboutProjectLink" Content="github.com/vidrug/aria2-winui3" NavigateUri="https://github.com/vidrug/aria2-winui3" />
                        </tk:SettingsCard>
                        <tk:SettingsCard x:Name="AriaInfoCard" Header="aria2">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE896;" />
                            </tk:SettingsCard.HeaderIcon>
                            <HyperlinkButton AutomationProperties.AutomationId="AboutAria2Link" Content="github.com/aria2/aria2" NavigateUri="https://github.com/aria2/aria2" />
                        </tk:SettingsCard>
                    </StackPanel>

                    <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False" IsClosable="False" Margin="0,8,0,16" />
                </StackPanel>
                </Grid>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</UserControl>
